<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
 "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Hardened Runtime entitlements for a GUI app that does not need
         network access to the Mac App Store sandbox. -->

    <!-- Allow JIT / compiled code execution (needed by PyTorch/NumPy) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Allow unsigned executable memory (needed by PyTorch JIT) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Allow loading of third-party plugins/libraries (needed by Pillow, HEIF) -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Incoming network connections (no server) -->
    <key>com.apple.security.network.server</key>
    <false/>

    <!-- Outgoing network connections (update check, download) -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- File read/write access (user opens folders) -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!-- Allow DYLD environment variables (needed by some Python C extensions) -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
</dict>
</plist>
